root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{json,geo.json}]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[*.{ts,tsx,js,jsx,css}]
indent_size = 2
quote_type = single

[*.{csproj,props,targets,sln}]
indent_size = 2

[*.cs]
indent_size = 4
end_of_line = crlf

#### Naamgeving — FO/TO-terminologie letterlijk aanhouden (src/CLAUDE.md) ####

dotnet_naming_rule.interfaces_beginnen_met_i.severity = warning
dotnet_naming_rule.interfaces_beginnen_met_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_beginnen_met_i.style = i_prefix_pascal
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.i_prefix_pascal.required_prefix = I
dotnet_naming_style.i_prefix_pascal.capitalization = pascal_case

dotnet_naming_rule.types_en_leden_pascal.severity = warning
dotnet_naming_rule.types_en_leden_pascal.symbols = type_and_member_symbols
dotnet_naming_rule.types_en_leden_pascal.style = pascal
dotnet_naming_symbols.type_and_member_symbols.applicable_kinds = class,struct,enum,property,method,event,delegate
dotnet_naming_style.pascal.capitalization = pascal_case

dotnet_naming_rule.private_velden_underscore.severity = warning
dotnet_naming_rule.private_velden_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_velden_underscore.style = underscore_camel
dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization = camel_case

#### Immutability & determinisme (src/CLAUDE.md) ####

# Domeintypes zijn immutable records; readonly waar het kan.
dotnet_style_readonly_field = true:warning
csharp_prefer_readonly_struct = true:suggestion
csharp_style_prefer_readonly_struct_member = true:suggestion

#### Guard clauses boven geneste if/else (src/CLAUDE.md, Clean Code) ####

csharp_style_prefer_pattern_matching = true:suggestion
csharp_style_prefer_not_pattern = true:suggestion
csharp_style_prefer_switch_expression = true:suggestion
csharp_style_throw_expression = true:suggestion
csharp_style_conditional_delegate_call = true:suggestion

#### Moderne C#-vorm ####

csharp_style_namespace_declarations = file_scoped:warning
csharp_using_directive_placement = outside_namespace:suggestion
csharp_prefer_braces = true:warning
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion
dotnet_style_object_initializer = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_prefer_conditional_expression_over_assignment = true:suggestion

csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

#### Opruimen — geen dode code laten staan (CLAUDE.md) ####

dotnet_diagnostic.IDE0005.severity = warning
dotnet_remove_unnecessary_suppression_exclusions = none

#### Layout ####

csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_space_after_keywords_in_control_flow_statements = true
dotnet_sort_system_directives_first = true
